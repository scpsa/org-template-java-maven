# Environment variables for this service.
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.

# ── Application ───────────────────────────────────────────────────────────────

# Port the application listens on inside the container (default: 8080)
APP_PORT=8080

# Active Spring profile (e.g. dev, staging, prod)
SPRING_PROFILES_ACTIVE=prod

# ── Docker image ──────────────────────────────────────────────────────────────

# Image name used when building or pulling
IMAGE_NAME=my-service

# Image tag to deploy (use a specific version in production, e.g. 1.2.3)
IMAGE_TAG=latest

# ── Debug (dev only) ──────────────────────────────────────────────────────────

# Host port mapped to the JVM debug port inside the dev container
DEBUG_PORT=5005
